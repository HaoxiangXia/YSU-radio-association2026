# 本地开发与部署都从本文件复制为 .env 后填写；.env 不提交到 Git。
PORT=5000

# SQLite 数据库路径。相对路径基于仓库根目录解析；缺省为 backend/data/database.sqlite。
# DATABASE_PATH=backend/data/database.sqlite

# JWT 签名密钥。必须设置为足够长的随机字符串，未设置时应用启动失败。
JWT_SECRET=replace-with-a-long-random-secret

# 招新负责人账号列表，格式：用户名:密码:姓名;用户名2:密码2:姓名2
# 密码必须是 PBKDF2 哈希，生成命令：cd backend && uv run python ../scripts/hash-password.py
# 未设置时应用启动失败。值中可能包含 $ 等字符，建议用双引号包裹。
RECRUITMENT_OFFICER_ACCOUNTS="username:pbkdf2_sha256$100000$...:姓名"

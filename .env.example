# 本地开发与部署都从本文件复制为 .env 后填写；.env 不提交到 Git。
NODE_ENV=development
PORT=5000

# 可使用绝对路径；本地默认可保留相对路径。
DATABASE_PATH=server/data/database.sqlite

# 单管理员后台。密码必须是 bcrypt 哈希，生成命令见 docs/RECRUITMENT_OPERATIONS.md。
ADMIN_USERNAME=replace-with-your-admin-name
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
JWT_SECRET=replace-with-a-long-random-secret

# 招新开关与开放时间（使用带时区的 ISO 时间）。
REGISTRATION_OPEN=false
REGISTRATION_START=2026-09-01T00:00:00+08:00
REGISTRATION_END=2026-09-15T23:59:59+08:00
REGISTRATION_NOTICE=报名尚未开放，请留意协会后续通知。
